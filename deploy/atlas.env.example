# Atlas environment file for systemd (copy to /etc/atlas/atlas.env, chmod 600).
# Secrets and host-specific overrides only — never commit the real file.

# --- secrets ---
ATLAS_DB_PASSWORD=change-me
# Comma-separated API keys; empty => the API fails closed (all v1 routes 401).
ATLAS_API_KEYS=change-me-key-1,change-me-key-2

# --- optional overrides (ATLAS_<SECTION>_<KEY>) ---
# Expose the API on the network (default binds 127.0.0.1):
# ATLAS_API_HOST=0.0.0.0
# ATLAS_API_PORT=8000
# Point at a non-local database / Ollama:
# ATLAS_DATABASE_HOST=localhost
# ATLAS_LLM_HOST=http://localhost:11434
