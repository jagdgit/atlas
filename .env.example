# Atlas secrets — copy to .env and fill in values
# NEVER commit .env to git

ATLAS_DB_PASSWORD=

# REST API keys (comma-separated). Clients authenticate with:
#   Authorization: Bearer <one-of-these-keys>
# Leave empty to keep the API fully locked (all protected routes return 401).
ATLAS_API_KEYS=

# Read-only email (S20d). Set host/username in config (plugins.mail.*); put the
# password here. Leave empty to keep the `mail` capability reporting "unavailable".
ATLAS_MAIL_PASSWORD=

# Stage 3.2 resource caps + OCR bounds (optional; defaults in config/defaults.yaml).
# ATLAS_RESOURCES_PROFILE=balanced
# ATLAS_RESOURCES_MAX_WORKER_THREADS=4
# ATLAS_RESOURCES_MAX_DOWNLOAD_WORKERS=4
# ATLAS_RESOURCES_MAX_READER_WORKERS=4
# ATLAS_RESOURCES_MAX_OCR_WORKERS=2
# ATLAS_RESOURCES_MAX_EXTRACT_WORKERS=2
# ATLAS_RESOURCES_OCR_MAX_PAGES=50
# ATLAS_RESOURCES_OCR_MAX_MINUTES=15
# ATLAS_RESOURCES_OCR_DPI=300
# Nested Stage 3.2d costs/budgets use full paths:
# ATLAS_RESOURCES_COSTS_LLM_EXTRACT_UNITS=15
# ATLAS_RESOURCES_COSTS_LLM_EXTRACT_RAM_MB=2100
# ATLAS_RESOURCES_BUDGETS_BALANCED=20
# LLM extract parallelism is also capped by ATLAS_LLM_MAX_CONCURRENCY (default 1).
# All LLM-heavy work shares the Resource Manager's global LLM lane.
# Stage 3.2e: async JobPlanner (create returns immediately; planner timeout separate):
# ATLAS_JOBS_PLANNER_TIMEOUT=60
# ATLAS_JOBS_PLANNER_NUM_PREDICT=512
# Profiles: conservative | balanced | maximum | overnight
# Overnight may prefer +1/+2 workers only inside MAX_WORKER_THREADS; never fails if busy.
