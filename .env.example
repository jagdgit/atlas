# Atlas secrets — copy to .env and fill in values
# NEVER commit .env to git

ATLAS_DB_PASSWORD=

# REST API keys (comma-separated). Clients authenticate with:
#   Authorization: Bearer <one-of-these-keys>
# Leave empty to keep the API fully locked (all protected routes return 401).
ATLAS_API_KEYS=

# Read-only email (S20d). Set host/username in config (plugins.mail.*); put the
# password here. Leave empty to keep the `mail` capability reporting "unavailable".
ATLAS_MAIL_PASSWORD=
