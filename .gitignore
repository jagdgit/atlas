# Data (runtime — lives in /data/atlas_data or at the repo root, NEVER source).
# Anchored with a leading "/" so these match ONLY top-level runtime dirs and do
# not swallow source packages like atlas/knowledge/, atlas/models/, atlas/documents/.
/documents/
/knowledge/
/logs/
/models/
/state/
/cache/
/backups/
/checkpoints/
/experiments/
/tmp/

